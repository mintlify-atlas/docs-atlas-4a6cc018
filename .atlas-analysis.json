  "keyFeatures": [
    "ChatGPT 4o-based prompting strategy for natural text parsing from PDFs",
    "Side-by-side evaluation toolkit for comparing different pipeline versions",
    "Language detection and SEO spam filtering",
    "Fine-tuning support for Qwen2-VL and Molmo-O models",
    "Distributed processing of millions of PDFs using SGlang",
    "Dolma-compatible output format for LLM training datasets",
    "Benchmark suite (olmOCR-Bench) for evaluating document parsing accuracy",
    "Local and cloud-based processing with AWS S3 integration",
    "Beaker cluster integration for large-scale processing",
    "Visual PDF viewer for side-by-side result comparison"
  ],
  "publicApiSurface": [
    "olmocr.pipeline - Main PDF processing pipeline",
    "olmocr.data.buildsilver - Generate silver training data using ChatGPT 4o",
    "olmocr.data.buildtestset - Create test datasets",
    "olmocr.data.renderpdf - Render PDFs to base64 PNG images",
    "olmocr.train.train - Fine-tune vision-language models",
    "olmocr.eval.runeval - Run evaluation benchmarks",
    "olmocr.filter.filter.PdfFilter - Filter PDFs by language and spam detection",
    "olmocr.viewer.dolmaviewer - View Dolma-format results with PDFs",
    "olmocr.work_queue - Distributed work queue management",
    "olmocr.prompts - Prompt templates for LLM interactions",
    "olmocr.bench - Benchmarking suite for OCR/parsing tools",
    "olmocr.s3_utils - AWS S3 utilities for cloud storage"
  ]
